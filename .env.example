HF_TOKEN=your_huggingface_token_here
# For OpenAI: https://api.openai.com/v1 | For HF inference router: https://router.huggingface.co/v1
API_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4.1-mini

# Local environment HTTP URL (inference.py when not using embedded Space URL)
# ENV_URL=http://127.0.0.1:8000

# Alternatively, use OPENAI_API_KEY (HF_TOKEN takes precedence if both are set)
# OPENAI_API_KEY=your_openai_key_here
